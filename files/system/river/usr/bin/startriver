#!/usr/bin/env bash

set -oue pipefail

# Default config that shipped with image
wayblue_origin_conf="/usr/etc/river/init"
# User's config path as per river documentation
river_conf="${XDG_CONFIG_HOME:-$HOME/.config}/river/init"

# Use the user's config only if it's both a regular file and executable
# Otherwise, launch river with default config that was shipped with image
if [ -f "$river_conf" ] && [ -x "$river_conf" ]; then
    exec river
else
    exec river -c "$wayblue_origin_conf"
fi